# Copy this file to .env and fill in values before running the server.

API_VERSION=0.1.0
LOG_LEVEL=INFO

# Model configuration
SENTIMENT_MODEL_NAME=distilbert-base-uncased
SENTIMENT_CHECKPOINT_PATH=checkpoints/sentiment/best_sentiment_model.pt
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Tokeniser
TOKENIZER_MAX_LENGTH=256

# Inference thresholds
NEGATIVE_THRESHOLD=-0.1
HDBSCAN_MIN_CLUSTER_SIZE=3
HDBSCAN_MIN_SAMPLES=2
TOP_KEYWORDS_PER_CLUSTER=5
MAX_OUTLIER_DISPLAY=5

# Server
CORS_ORIGINS=*
