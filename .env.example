# Copy this file to .env and fill in values before running the server.

API_VERSION=0.1.0
LOG_LEVEL=INFO

# Model configuration
SENTIMENT_MODEL_NAME=savasy/bert-base-turkish-sentiment-cased
SENTIMENT_CHECKPOINT_PATH=checkpoints/sentiment/best_sentiment_model.pt
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Tokeniser
TOKENIZER_MAX_LENGTH=256

# Inference thresholds
NEGATIVE_THRESHOLD=-0.1
HDBSCAN_MIN_CLUSTER_SIZE=3
HDBSCAN_MIN_SAMPLES=2
TOP_KEYWORDS_PER_CLUSTER=5
MAX_OUTLIER_DISPLAY=5

# Server
# CORS_ORIGINS must be a concrete origin list before this goes to production
# (no "*" — see app/main.py for why). The extension itself isn't gated by
# CORS_ORIGINS; it authenticates via EXTENSION_API_KEY below.
CORS_ORIGINS=https://your-production-domain.example

# Shared secret the extension sends as the X-API-KEY header. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Requests without a matching key are rejected with 401.
EXTENSION_API_KEY=

# slowapi rate limit applied to /analyze and /analyze/batch.
ANALYZE_RATE_LIMIT=20/minute
